# =============================================================================
# .gitignore for jobs/
#
# COMMITTED (not ignored):
#   site/data.json   — pre-built dataset served by Vercel; must be in the repo
#   site/index.html  — single-file app; must be in the repo
#
# REPRODUCIBLE (ignored — regenerate with the commands below):
#   html/            — re-scrape with scrape.py
#   occupational_outlook_handbook.html — re-scrape with scrape.py
#   data/            — raw data folder, re-generated from scrape output
#   pages/           — re-generated via process.py
#   (scores.json remains committed so data rebuilds work out-of-the-box)
# =============================================================================

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo
*.egg-info

# Build / distribution artifacts
dist/
build/
wheels/

# Virtual environments
.venv/
venv/

# Secrets
.env
.env.*
!.env.example

# Large scraped HTML files (342 files, reproducible via scrape.py)
html/

# Single large scraped source file (reproducible via scrape.py)
occupational_outlook_handbook.html

# Raw data folder (reproducible)
data/

# Parsed markdown pages (reproducible via process.py)
pages/

# Embeddings (unused in final visualization)
embeddings.json

# Vercel local config
.vercel

# Local deployment notes (not for public repo)
DEPLOY.md

# macOS
.DS_Store

# Windows
Thumbs.db

# Logs
*.log

# Local deployment notes (not for public repo)
DEPLOY.md
